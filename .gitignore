### Laravel ###
# Laravel 4 specific
bootstrap/compiled.php
app/storage/

# Laravel 5 & Lumen specific
public/storage
public/hot

# Laravel 5 & Lumen specific with changed public path
public_html/storage
public_html/hot

bootstrap/cache

# Environment and dependencies
.env
.env.backup
.env.production
.DS_Store
/vendor/
/node_modules/
/storage/app/update-file/
/storage/app/firebase/*.json
/storage/app/database.sql
